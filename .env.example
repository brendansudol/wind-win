# Strava API application (create one at https://www.strava.com/settings/api).
# Set the app's "Authorization Callback Domain" to: redirect
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Development only — token exchange happens directly in the app with this
# secret. Anyone with the binary can extract it, so before releasing, deploy
# proxy/strava-token-proxy.js and use the proxy URL instead.
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=

# Production path: URL of the deployed token proxy (leave the secret above
# empty when this is set).
EXPO_PUBLIC_STRAVA_TOKEN_PROXY_URL=

# Dev only: "lat,lon" fallback used when real location is unavailable
# (e.g. web preview with geolocation blocked). Ignored in release builds.
EXPO_PUBLIC_DEV_FAKE_LOCATION=
